# ─── Tests ────────────────────────────────────────────────────────────────────

cmd_test() {
  local _T_PASSED=0 _T_FAILED=0 _T_SKIPPED=0
  local -a _T_FAIL_DETAILS=()

  _t_pass() { ((_T_PASSED++)) || true; echo -e "  ${GREEN}✓${RESET} $1"; }
  _t_fail() { ((_T_FAILED++)) || true; echo -e "  ${RED}✗${RESET} $1"; _T_FAIL_DETAILS+=("$1"); }
  _t_skip() { ((_T_SKIPPED++)) || true; echo -e "  ${DIM}○${RESET} $1 ${DIM}(skipped)${RESET}"; }

  _t_check() {
    local desc="$1"; shift
    if "$@" &>/dev/null; then _t_pass "$desc"; else _t_fail "$desc"; fi
  }

  _t_check_fail() {
    local desc="$1"; shift
    if ! "$@" &>/dev/null; then _t_pass "$desc"; else _t_fail "$desc"; fi
  }

  _t_grep() {
    local desc="$1" pattern="$2"; shift 2
    local output
    if output="$("$@" 2>&1)" && echo "$output" | grep -qE "$pattern"; then
      _t_pass "$desc"
    else
      _t_fail "$desc"
    fi
  }

  _section() { echo ""; echo -e "${BOLD}$1${RESET}"; }

  echo ""
  echo -e "${BOLD}${SCRIPT_NAME} v${VERSION} — test suite${RESET}"

  local TMPBASE
  TMPBASE="$(mktemp -d)"
  # macOS /var → /private/var symlink; resolve so paths match git output
  TMPBASE="$(cd "$TMPBASE" && pwd -P)"
  # shellcheck disable=SC2064
  trap "tmux kill-session -t dev-repo 2>/dev/null || true; tmux kill-session -t del-repo 2>/dev/null || true; tmux kill-session -t tmux-repo 2>/dev/null || true; rm -rf '${TMPBASE}'" EXIT

  export KDEV_TEST_NO_ATTACH=1

  # ─── G — Git helpers ─────────────────────────────────────────────────
  _section "G — Git helpers"

  local test_repo="$TMPBASE/test-repo"
  mkdir -p "$test_repo"
  git -C "$test_repo" init --quiet
  git -C "$test_repo" commit --allow-empty -m "initial" --quiet

  # G1: _find_repo_root from repo root
  local g1_result
  g1_result="$(cd "$test_repo" && _find_repo_root)"
  if [[ "$g1_result" == "$test_repo" ]]; then
    _t_pass "G1 _find_repo_root from repo root"
  else
    _t_fail "G1 _find_repo_root from repo root — got '$g1_result'"
  fi

  # G2: _git_is_dirty detects clean repo (before creating untracked files)
  if ! _git_is_dirty "$test_repo"; then
    _t_pass "G2 _git_is_dirty reports clean repo"
  else
    _t_fail "G2 _git_is_dirty reports clean repo"
  fi

  # G3: _git_is_dirty detects dirty repo
  echo "dirty" > "$test_repo/dirty-file.txt"
  if _git_is_dirty "$test_repo"; then
    _t_pass "G3 _git_is_dirty reports dirty repo"
  else
    _t_fail "G3 _git_is_dirty reports dirty repo"
  fi
  rm -f "$test_repo/dirty-file.txt"

  # G4: _find_repo_root from subdirectory
  mkdir -p "$test_repo/sub/dir"
  local g4_result
  g4_result="$(cd "$test_repo/sub/dir" && _find_repo_root)"
  if [[ "$g4_result" == "$test_repo" ]]; then
    _t_pass "G4 _find_repo_root from subdirectory"
  else
    _t_fail "G4 _find_repo_root from subdirectory — got '$g4_result'"
  fi

  # G5: _find_repo_root from worktree
  mkdir -p "$test_repo/$WORKTREES_DIR"
  git -C "$test_repo" worktree add "$test_repo/$WORKTREES_DIR/test-wt" -b test-wt --quiet
  local g5_result
  g5_result="$(cd "$test_repo/$WORKTREES_DIR/test-wt" && _find_repo_root)"
  if [[ "$g5_result" == "$test_repo" ]]; then
    _t_pass "G5 _find_repo_root from worktree"
  else
    _t_fail "G5 _find_repo_root from worktree — got '$g5_result'"
  fi

  # G6: _find_repo_root fails outside git repo
  if ! (cd "$TMPBASE" && _find_repo_root) &>/dev/null; then
    _t_pass "G6 _find_repo_root fails outside git repo"
  else
    _t_fail "G6 _find_repo_root fails outside git repo"
  fi

  # G7: _tmux_session_name sanitizes dots and colons
  if [[ "$(_tmux_session_name "my.project:1")" == "my_project_1" ]]; then
    _t_pass "G7 _tmux_session_name sanitizes dots and colons"
  else
    _t_fail "G7 _tmux_session_name sanitizes dots and colons"
  fi

  # G8: _ensure_gitignore adds entry
  local gi_repo="$TMPBASE/gi-repo"
  mkdir -p "$gi_repo"
  _ensure_gitignore "$gi_repo" ".worktrees"
  if grep -qxF ".worktrees" "$gi_repo/.gitignore"; then
    _t_pass "G8 _ensure_gitignore adds entry"
  else
    _t_fail "G8 _ensure_gitignore adds entry"
  fi

  # G9: _ensure_gitignore is idempotent
  _ensure_gitignore "$gi_repo" ".worktrees"
  local gi_count
  gi_count=$(grep -cxF ".worktrees" "$gi_repo/.gitignore")
  if [[ "$gi_count" == "1" ]]; then
    _t_pass "G9 _ensure_gitignore is idempotent"
  else
    _t_fail "G9 _ensure_gitignore is idempotent — found $gi_count entries"
  fi

  # G10: _git_default_branch detects default branch
  local default_branch
  default_branch="$(_git_default_branch "$test_repo")" || default_branch=""
  if [[ "$default_branch" == "main" || "$default_branch" == "master" ]]; then
    _t_pass "G10 _git_default_branch detects default branch ($default_branch)"
  else
    _t_fail "G10 _git_default_branch detects default branch — got '$default_branch'"
  fi

  # Clean up test worktree
  git -C "$test_repo" worktree remove "$test_repo/$WORKTREES_DIR/test-wt" --force 2>/dev/null || true

  # ─── C — Config content ──────────────────────────────────────────────
  _section "C — Config content"

  local tmux_content
  tmux_content="$(_tmux_conf_content)"

  # C1: tmux conf includes prefix C-a
  if echo "$tmux_content" | grep -q "prefix C-a"; then
    _t_pass "C1 tmux conf includes prefix C-a"
  else
    _t_fail "C1 tmux conf includes prefix C-a"
  fi

  # C2: tmux conf includes M-h pane navigation
  if echo "$tmux_content" | grep -q "M-h select-pane -L"; then
    _t_pass "C2 tmux conf includes M-h pane navigation"
  else
    _t_fail "C2 tmux conf includes M-h pane navigation"
  fi

  # C3: tmux conf includes tmux-resurrect
  if echo "$tmux_content" | grep -q "tmux-resurrect"; then
    _t_pass "C3 tmux conf includes tmux-resurrect"
  else
    _t_fail "C3 tmux conf includes tmux-resurrect"
  fi

  # C4: tmux conf includes quick-window bindings
  if echo "$tmux_content" | grep -q 'bind g new-window'; then
    _t_pass "C4 tmux conf includes quick-window bindings"
  else
    _t_fail "C4 tmux conf includes quick-window bindings"
  fi

  # C5: alacritty keys include option_as_alt
  local alacritty_content
  alacritty_content="$(_alacritty_keys_content)"
  if echo "$alacritty_content" | grep -q 'option_as_alt'; then
    _t_pass "C5 alacritty keys include option_as_alt"
  else
    _t_fail "C5 alacritty keys include option_as_alt"
  fi

  # C6: alacritty keys include begin/end markers
  if echo "$alacritty_content" | grep -qF "$_ALACRITTY_MARKER_BEGIN" \
     && echo "$alacritty_content" | grep -qF "$_ALACRITTY_MARKER_END"; then
    _t_pass "C6 alacritty keys include begin/end markers"
  else
    _t_fail "C6 alacritty keys include begin/end markers"
  fi

  # C7: alacritty re-run replaces block (no duplicates)
  local test_alacritty="$TMPBASE/alacritty.toml"
  echo '[colors.primary]' > "$test_alacritty"
  echo 'background = "#000000"' >> "$test_alacritty"
  # First append
  _alacritty_keys_content >> "$test_alacritty"
  # Simulate second run: remove begin/end block and re-append
  sed -i '' "/$_ALACRITTY_MARKER_BEGIN/,/$_ALACRITTY_MARKER_END/d" "$test_alacritty"
  _alacritty_keys_content >> "$test_alacritty"
  local marker_count
  marker_count=$(grep -cF "$_ALACRITTY_MARKER_BEGIN" "$test_alacritty")
  if [[ "$marker_count" == "1" ]]; then
    _t_pass "C7 alacritty re-run replaces block (no duplicates)"
  else
    _t_fail "C7 alacritty re-run replaces block — found $marker_count begin markers"
  fi

  # C8: alacritty legacy Cmd+hjkl block gets cleaned up
  local test_legacy="$TMPBASE/alacritty-legacy.toml"
  echo '[colors.primary]' > "$test_legacy"
  echo 'background = "#000000"' >> "$test_legacy"
  echo '' >> "$test_legacy"
  echo '# --- zproj-kostek: Cmd+hjkl tmux pane navigation ---' >> "$test_legacy"
  echo '[[keyboard.bindings]]' >> "$test_legacy"
  echo 'key = "H"' >> "$test_legacy"
  echo 'mods = "Command"' >> "$test_legacy"
  echo 'chars = "\u001bh"' >> "$test_legacy"
  # Simulate what _append_alacritty_keys does for legacy cleanup
  if grep -qF "$_ALACRITTY_LEGACY_MARKER" "$test_legacy" 2>/dev/null; then
    sed -i '' "/$_ALACRITTY_LEGACY_MARKER/,/^$/{ /^$/!d; }" "$test_legacy"
    sed -i '' '/^\[\[keyboard\.bindings\]\]/,/^$/{/^$/!d;}' "$test_legacy"
  fi
  _alacritty_keys_content >> "$test_legacy"
  if grep -qF "$_ALACRITTY_MARKER_BEGIN" "$test_legacy" \
     && ! grep -q 'mods = "Command"' "$test_legacy"; then
    _t_pass "C8 legacy Cmd+hjkl block cleaned up on migration"
  else
    _t_fail "C8 legacy Cmd+hjkl block cleaned up on migration"
  fi

  # C9: tmux conf includes swap-pane bindings
  if echo "$tmux_content" | grep -q "M-H swap-pane"; then
    _t_pass "C9 tmux conf includes pane swap bindings"
  else
    _t_fail "C9 tmux conf includes pane swap bindings"
  fi

  # C10: tmux conf includes zoom toggle
  if echo "$tmux_content" | grep -q "M-F resize-pane -Z"; then
    _t_pass "C10 tmux conf includes zoom toggle binding"
  else
    _t_fail "C10 tmux conf includes zoom toggle binding"
  fi

  # ─── D — Dev command ──────────────────────────────────────────────────
  _section "D — Dev command"

  local dev_repo="$TMPBASE/dev-repo"
  mkdir -p "$dev_repo"
  git -C "$dev_repo" init --quiet
  git -C "$dev_repo" commit --allow-empty -m "initial" --quiet

  # D1: dev creates worktree
  (cd "$dev_repo" && cmd_dev "test-feature") &>/dev/null
  if [[ -d "$dev_repo/$WORKTREES_DIR/test-feature" ]]; then
    _t_pass "D1 dev creates worktree in $WORKTREES_DIR/"
  else
    _t_fail "D1 dev creates worktree in $WORKTREES_DIR/"
  fi

  # D2: dev creates correct branch
  local wt_branch
  wt_branch="$(git -C "$dev_repo/$WORKTREES_DIR/test-feature" rev-parse --abbrev-ref HEAD 2>/dev/null)"
  if [[ "$wt_branch" == "test-feature" ]]; then
    _t_pass "D2 dev creates correct branch"
  else
    _t_fail "D2 dev creates correct branch — got '$wt_branch'"
  fi

  # D3: dev with existing worktree succeeds (re-launch)
  if (cd "$dev_repo" && cmd_dev "test-feature") &>/dev/null; then
    _t_pass "D3 dev with existing worktree succeeds (re-launch)"
  else
    _t_fail "D3 dev with existing worktree succeeds (re-launch)"
  fi

  # D4: dev adds .worktrees to .gitignore
  if grep -qxF "$WORKTREES_DIR" "$dev_repo/.gitignore" 2>/dev/null; then
    _t_pass "D4 dev adds $WORKTREES_DIR to .gitignore"
  else
    _t_fail "D4 dev adds $WORKTREES_DIR to .gitignore"
  fi

  # D5: dev fails without name
  if ! (cd "$dev_repo" && cmd_dev) &>/dev/null; then
    _t_pass "D5 dev fails without name argument"
  else
    _t_fail "D5 dev fails without name argument"
  fi

  # D6: dev fails outside git repo
  local no_git_dir="$TMPBASE/no-git"
  mkdir -p "$no_git_dir"
  if ! (cd "$no_git_dir" && cmd_dev "test") &>/dev/null; then
    _t_pass "D6 dev fails outside git repo"
  else
    _t_fail "D6 dev fails outside git repo"
  fi

  # D7: dev --from creates worktree at specific ref
  git -C "$dev_repo" tag v-test-from
  (cd "$dev_repo" && cmd_dev "from-tag" --from v-test-from) &>/dev/null
  if [[ -d "$dev_repo/$WORKTREES_DIR/from-tag" ]]; then
    _t_pass "D7 dev --from creates worktree at specific ref"
  else
    _t_fail "D7 dev --from creates worktree at specific ref"
  fi

  # D8: dev rejects invalid branch name
  if ! (cd "$dev_repo" && cmd_dev "bad..name") &>/dev/null; then
    _t_pass "D8 dev rejects invalid branch name"
  else
    _t_fail "D8 dev rejects invalid branch name"
  fi

  # D9: dev --from with bad ref fails
  if ! (cd "$dev_repo" && cmd_dev "bad-ref-wt" --from "nonexistent-ref-xyz") &>/dev/null; then
    _t_pass "D9 dev --from with bad ref fails"
  else
    _t_fail "D9 dev --from with bad ref fails"
  fi

  # Clean up dev-repo tmux session
  tmux kill-session -t dev-repo 2>/dev/null || true

  # ─── L — List command ─────────────────────────────────────────────────
  _section "L — List command"

  # L1: list shows worktrees
  local list_output
  list_output="$(cd "$dev_repo" && cmd_list 2>&1)"
  if echo "$list_output" | grep -q "test-feature"; then
    _t_pass "L1 list shows created worktrees"
  else
    _t_fail "L1 list shows created worktrees"
  fi

  # L2: list shows multiple worktrees
  if echo "$list_output" | grep -q "from-tag"; then
    _t_pass "L2 list shows multiple worktrees"
  else
    _t_fail "L2 list shows multiple worktrees"
  fi

  # L3: list fails outside git repo
  if ! (cd "$no_git_dir" && cmd_list) &>/dev/null; then
    _t_pass "L3 list fails outside git repo"
  else
    _t_fail "L3 list fails outside git repo"
  fi

  # L4: list with no worktrees shows helpful message
  local empty_repo="$TMPBASE/empty-repo"
  mkdir -p "$empty_repo"
  git -C "$empty_repo" init --quiet
  git -C "$empty_repo" commit --allow-empty -m "initial" --quiet
  local l4_output
  l4_output="$(cd "$empty_repo" && cmd_list 2>&1)"
  if echo "$l4_output" | grep -q "No worktrees found"; then
    _t_pass "L4 list with no worktrees shows helpful message"
  else
    _t_fail "L4 list with no worktrees shows helpful message"
  fi

  # ─── X — Delete command ──────────────────────────────────────────────
  _section "X — Delete command"

  local del_repo="$TMPBASE/del-repo"
  mkdir -p "$del_repo"
  git -C "$del_repo" init --quiet
  git -C "$del_repo" commit --allow-empty -m "initial" --quiet

  # Create a worktree to delete
  (cd "$del_repo" && cmd_dev "to-delete") &>/dev/null
  tmux kill-session -t del-repo 2>/dev/null || true

  # X1: delete removes worktree directory
  (cd "$del_repo" && cmd_delete "to-delete") &>/dev/null
  if [[ ! -d "$del_repo/$WORKTREES_DIR/to-delete" ]]; then
    _t_pass "X1 delete removes worktree directory"
  else
    _t_fail "X1 delete removes worktree directory"
  fi

  # X2: delete removes branch
  if ! git -C "$del_repo" show-ref --verify --quiet "refs/heads/to-delete"; then
    _t_pass "X2 delete removes branch"
  else
    _t_fail "X2 delete removes branch"
  fi

  # X3: delete fails on non-existent worktree
  if ! (cd "$del_repo" && cmd_delete "nonexistent") &>/dev/null; then
    _t_pass "X3 delete fails on non-existent worktree"
  else
    _t_fail "X3 delete fails on non-existent worktree"
  fi

  # X4: delete --force removes dirty worktree
  (cd "$del_repo" && cmd_dev "dirty-wt") &>/dev/null
  tmux kill-session -t del-repo 2>/dev/null || true
  echo "dirty" > "$del_repo/$WORKTREES_DIR/dirty-wt/dirty-file.txt"
  if (cd "$del_repo" && cmd_delete "dirty-wt" --force) &>/dev/null; then
    _t_pass "X4 delete --force removes dirty worktree"
  else
    _t_fail "X4 delete --force removes dirty worktree"
  fi

  # X5: delete without --force fails on dirty worktree
  (cd "$del_repo" && cmd_dev "dirty-wt2") &>/dev/null
  tmux kill-session -t del-repo 2>/dev/null || true
  echo "dirty" > "$del_repo/$WORKTREES_DIR/dirty-wt2/dirty-file.txt"
  if ! (cd "$del_repo" && cmd_delete "dirty-wt2") &>/dev/null; then
    _t_pass "X5 delete without --force fails on dirty worktree"
  else
    _t_fail "X5 delete without --force fails on dirty worktree"
  fi

  # Clean up remaining del-repo worktrees
  git -C "$del_repo" worktree remove "$del_repo/$WORKTREES_DIR/dirty-wt2" --force 2>/dev/null || true

  # ─── T — tmux layout ─────────────────────────────────────────────────
  if command -v tmux &>/dev/null; then
    _section "T — tmux layout"

    local tmux_repo="$TMPBASE/tmux-repo"
    mkdir -p "$tmux_repo"
    git -C "$tmux_repo" init --quiet
    git -C "$tmux_repo" commit --allow-empty -m "initial" --quiet

    (cd "$tmux_repo" && cmd_dev "tmux-test") &>/dev/null

    local tmux_session
    tmux_session="$(_tmux_session_name "tmux-repo")"

    # T1: dev creates tmux session
    if tmux has-session -t "$tmux_session" 2>/dev/null; then
      _t_pass "T1 dev creates tmux session"
    else
      _t_fail "T1 dev creates tmux session"
    fi

    # T2: session has 3 panes
    local pane_count
    pane_count="$(tmux list-panes -t "$tmux_session:tmux-test" -F '#{pane_id}' 2>/dev/null | wc -l | tr -d ' ')"
    if [[ "$pane_count" == "3" ]]; then
      _t_pass "T2 session has 3 panes"
    else
      _t_fail "T2 session has 3 panes — got $pane_count"
    fi

    # T3: window named correctly
    local window_names
    window_names="$(tmux list-windows -t "$tmux_session" -F '#{window_name}' 2>/dev/null)"
    if echo "$window_names" | grep -qx "tmux-test"; then
      _t_pass "T3 window named correctly"
    else
      _t_fail "T3 window named correctly — got '$window_names'"
    fi

    # T4: second dev call reuses existing window
    (cd "$tmux_repo" && cmd_dev "tmux-test") &>/dev/null
    local window_count
    window_count="$(tmux list-windows -t "$tmux_session" -F '#{window_name}' 2>/dev/null | wc -l | tr -d ' ')"
    if [[ "$window_count" == "1" ]]; then
      _t_pass "T4 second dev call reuses existing window"
    else
      _t_fail "T4 second dev call reuses existing window — got $window_count windows"
    fi

    # T5: launch command works for existing worktree
    if (cd "$tmux_repo" && cmd_launch "tmux-test") &>/dev/null; then
      _t_pass "T5 launch works for existing worktree"
    else
      _t_fail "T5 launch works for existing worktree"
    fi

    # T6: launch fails for non-existent worktree
    if ! (cd "$tmux_repo" && cmd_launch "nonexistent") &>/dev/null; then
      _t_pass "T6 launch fails for non-existent worktree"
    else
      _t_fail "T6 launch fails for non-existent worktree"
    fi

    tmux kill-session -t "$tmux_session" 2>/dev/null || true
  else
    _section "T — tmux layout (skipped — tmux not installed)"
    _t_skip "T1 dev creates tmux session"
    _t_skip "T2 session has 3 panes"
    _t_skip "T3 window named correctly"
    _t_skip "T4 second dev call reuses existing window"
    _t_skip "T5 launch works for existing worktree"
    _t_skip "T6 launch fails for non-existent worktree"
  fi

  # ─── S — Setup ───────────────────────────────────────────────────────
  _section "S — Setup"

  _t_grep "S1 setup --plan lists tools" "Tools:" cmd_setup --plan
  _t_grep "S2 setup --plan lists configs" "Configs:" cmd_setup --plan
  _t_grep "S3 setup --plan is non-destructive" "installed|would" cmd_setup --plan

  # ─── V — Meta ────────────────────────────────────────────────────────
  _section "V — Meta"

  _t_grep "V1 --version shows version" "$VERSION" main --version
  _t_grep "V2 --help shows usage" "Usage:" main --help

  # V3: version is valid semver
  if [[ "$VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    _t_pass "V3 version is valid semver"
  else
    _t_fail "V3 version is valid semver — got '$VERSION'"
  fi

  # V4: unknown option fails
  if ! (main "--totally-fake-option") &>/dev/null; then
    _t_pass "V4 unknown option fails"
  else
    _t_fail "V4 unknown option fails"
  fi

  # ─── Summary ──────────────────────────────────────────────────────────
  echo ""
  echo -e "─────────────────────────────────────"
  local total=$((_T_PASSED + _T_FAILED + _T_SKIPPED))

  if [[ $_T_FAILED -eq 0 ]]; then
    echo -e "${GREEN}All ${total} tests passed${RESET} (${_T_SKIPPED} skipped)"
  else
    echo -e "${RED}${_T_FAILED} failed${RESET}, ${GREEN}${_T_PASSED} passed${RESET}, ${_T_SKIPPED} skipped"
    echo ""
    echo -e "${RED}Failures:${RESET}"
    local detail
    for detail in "${_T_FAIL_DETAILS[@]}"; do
      echo -e "  ${RED}✗${RESET} $detail"
    done
  fi
  echo ""

  unset KDEV_TEST_NO_ATTACH
  [[ $_T_FAILED -eq 0 ]]
}

# ─── Main dispatch ────────────────────────────────────────────────────────────

main() {
  case "${1:-}" in
    dev)        shift; cmd_dev "$@" ;;
    launch)     shift; cmd_launch "$@" ;;
    list)       shift; cmd_list "$@" ;;
    delete)     shift; cmd_delete "$@" ;;
    setup)      shift; cmd_setup "$@" ;;
    --version)  echo "$SCRIPT_NAME $VERSION" ;;
    --help|-h)  usage_main ;;
    --test)     cmd_test ;;
    "")         usage_main ;;
    -*)         die "Unknown option: $1.\n  Run ${CYAN}$SCRIPT_NAME --help${RESET} for usage." ;;
    *)          cmd_dev "$@" ;;
  esac
}

main "$@"
