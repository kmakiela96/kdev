Commands:
  dev <name> [--from <ref>]   Create worktree and start dev session
  launch <name>               Launch session for existing worktree
  list                        List worktrees and their status
  delete <name> [--force]     Remove a worktree
  setup [--plan]              Install tools and write configs

Options:
  --version   Show version
  --help      Show this help
  --test      Run test suite

Running '$SCRIPT_NAME <name>' without a subcommand is the same as 'dev <name>'.
EOF
}

usage_dev() {
  cat <<EOF
Usage: $SCRIPT_NAME dev <name> [--from <ref>]

Create a git worktree and start a tmux dev session with 3-pane layout:

  ┌──────────────────┬──────────────────┐
  │                  │    lazygit       │
  │    pi agent      │   (top-right)    │
