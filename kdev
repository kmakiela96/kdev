# ─── Completion generators ────────────────────────────────────────────────────

# Helper used inside both completion functions: lists worktree names from the
# repo root, tolerating being called from inside a worktree or any subdirectory.
# Outputs nothing (silently) if not inside a git repo or no worktrees exist.
_completions_worktrees() {
  cat <<'SH'
  local _root
  _root="$(git rev-parse --show-toplevel 2>/dev/null)" || return 0
  local _parent_name
  _parent_name="$(basename "$(dirname "$_root")")"
  [[ "$_parent_name" == ".worktrees" ]] && _root="$(dirname "$(dirname "$_root")")"
  local _wt_base="$_root/.worktrees"
  [[ -d "$_wt_base" ]] || return 0
  local d
  for d in "$_wt_base"/*/; do
    [[ -d "$d" ]] && printf '%s\n' "$(basename "$d")"
  done
SH
}

_completions_zsh() {
  local worktree_finder
  worktree_finder="$(_completions_worktrees)"

  cat <<ZSHCOMP
# kdev zsh completions — generated by: eval "\$(kdev --completions zsh)"
_kdev() {
  local state
  local -a subcommands worktrees

  subcommands=(
    'dev:Create worktree and start dev session'
    'launch:Launch session for existing worktree'
    'list:List worktrees and their status'
    'delete:Remove a worktree'
    'setup:Install tools and write configs'
  )

  _kdev_worktrees() {
${worktree_finder}
  }

  _arguments -C \\
    '1: :->first' \\
    '*: :->rest' && return

  case "\$state" in
    first)
      local -a wts=("\${(@f)\$(_kdev_worktrees)}")
      local -a wt_specs=()
      local w
      for w in "\${wts[@]}"; do
        wt_specs+=("\${w}:worktree")
      done
      _describe 'command or worktree' subcommands -- wt_specs
      ;;
    rest)
      case "\${words[2]}" in
        dev)
          case "\${words[CURRENT]}" in
            --*) _arguments '--from[Base ref for new branch]:ref' '--help' ;;
            *)
              if [[ "\${words[CURRENT-1]}" == "--from" ]]; then
                # completing a ref — skip
                return
              fi
              local -a wts=("\${(@f)\$(_kdev_worktrees)}")
              [[ \${#wts[@]} -gt 0 ]] && _describe 'existing worktree' wts
              ;;
          esac
          ;;
        launch)
          local -a wts=("\${(@f)\$(_kdev_worktrees)}")
          [[ \${#wts[@]} -gt 0 ]] && _describe 'worktree' wts
          ;;
        delete)
          case "\${words[CURRENT]}" in
            --*) _arguments '--force[Force removal]' '--help' ;;
            *)
              local -a wts=("\${(@f)\$(_kdev_worktrees)}")
              [[ \${#wts[@]} -gt 0 ]] && _describe 'worktree' wts
              ;;
          esac
          ;;
        setup)
          _arguments '--plan[Dry run]' '--help'
          ;;
        --completions)
          local shells=(bash zsh)
          _describe 'shell' shells
          ;;
        *)
          _arguments '--version' '--help' '--test' '--completions[Output completions]:shell:(bash zsh)'
          ;;
      esac
      ;;
  esac
}
compdef _kdev kdev
ZSHCOMP
}

_completions_bash() {
  local worktree_finder
  worktree_finder="$(_completions_worktrees)"

  cat <<BASHCOMP
# kdev bash completions — generated by: eval "\$(kdev --completions bash)"
_kdev() {
  local cur prev words cword
  _init_completion 2>/dev/null || {
    cur="\${COMP_WORDS[COMP_CWORD]}"
    prev="\${COMP_WORDS[COMP_CWORD-1]}"
    words=("\${COMP_WORDS[@]}")
    cword=\$COMP_CWORD
  }

  _kdev_worktrees() {
${worktree_finder}
  }

  local subcommands="dev launch list delete setup"

  if [[ \$cword -eq 1 ]]; then
    local wts
    wts="\$(_kdev_worktrees)"
    COMPREPLY=(\$(compgen -W "\$subcommands \$wts" -- "\$cur"))
    return
  fi

  local subcmd="\${words[1]}"
  case "\$subcmd" in
    dev)
      if [[ "\$cur" == --* ]]; then
        COMPREPLY=(\$(compgen -W "--from --help" -- "\$cur"))
      else
        local wts
        wts="\$(_kdev_worktrees)"
        [[ -n "\$wts" ]] && COMPREPLY=(\$(compgen -W "\$wts" -- "\$cur"))
      fi
      ;;
    launch)
      local wts
      wts="\$(_kdev_worktrees)"
      [[ -n "\$wts" ]] && COMPREPLY=(\$(compgen -W "\$wts" -- "\$cur"))
      ;;
    delete)
      if [[ "\$cur" == --* ]]; then
        COMPREPLY=(\$(compgen -W "--force --help" -- "\$cur"))
      else
        local wts
        wts="\$(_kdev_worktrees)"
        [[ -n "\$wts" ]] && COMPREPLY=(\$(compgen -W "\$wts" -- "\$cur"))
      fi
      ;;
    setup)
      COMPREPLY=(\$(compgen -W "--plan --help" -- "\$cur"))
      ;;
    --completions)
      COMPREPLY=(\$(compgen -W "bash zsh" -- "\$cur"))
      ;;
    *)
      COMPREPLY=(\$(compgen -W "--version --help --test --completions" -- "\$cur"))
      ;;
  esac
}
complete -F _kdev kdev
BASHCOMP
}

# ─── Setup functions ─────────────────────────────────────────────────────────

_check_brew() {
  command -v brew &>/dev/null && return 0
  die "Homebrew not found. Install it first:\n\n  /bin/bash -c \"\$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)\"\n\nhttps://brew.sh"
}

_install_brew_formula() {
  local name="$1" binary="${2:-$1}"
  if command -v "$binary" &>/dev/null; then
    dim "  [installed]  $name"
    return 0
  fi
  step "Installing ${CYAN}${name}${RESET}..."
  brew install "$name"
  info "$name installed"
}

_install_brew_cask() {
  local name="$1" binary="${2:-$1}"
  if command -v "$binary" &>/dev/null; then
    dim "  [installed]  $name"
    return 0
  fi
  step "Installing ${CYAN}${name}${RESET} (cask)..."
  brew install --cask "$name"
  info "$name installed"
}

_install_pi_agent() {
  if command -v pi &>/dev/null; then
    dim "  [installed]  pi-coding-agent"
    return 0
  fi
  step "Installing ${CYAN}pi-coding-agent${RESET} via npm..."
  npm install -g @mariozechner/pi-coding-agent
  info "pi-coding-agent installed"
}

_write_tmux_conf() {
  local conf_dir="$HOME/.config/tmux"
  local conf_file="$conf_dir/tmux.conf"
  local old_conf="$HOME/.tmux.conf"

  # Back up ~/.tmux.conf so tmux reads the XDG-compliant location
  if [[ -f "$old_conf" ]]; then
    local backup="${old_conf}.bak"
    local n=1
    while [[ -f "$backup" ]]; do
      backup="${old_conf}.bak${n}"
      ((n++))
    done
    mv "$old_conf" "$backup"
    step "Backed up ${DIM}~/.tmux.conf${RESET} → ${DIM}$(basename "$backup")${RESET}"
  fi

  mkdir -p "$conf_dir"
  _tmux_conf_content > "$conf_file"
  info "Wrote ${conf_file}"
}

_write_alacritty_conf() {
  local conf_dir="$HOME/.config/alacritty"
  local conf_file="$conf_dir/alacritty.toml"

  if [[ -f "$conf_file" ]] && grep -qF "generated by kdev" "$conf_file"; then
    dim "  [up to date]  alacritty.toml"
    return 0
  fi

  if [[ -f "$conf_file" ]]; then
    local backup="${conf_file}.bak"
    local n=1
    while [[ -f "$backup" ]]; do
      backup="${conf_file}.bak${n}"
      ((n++))
    done
    mv "$conf_file" "$backup"
    step "Backed up ${DIM}alacritty.toml${RESET} → ${DIM}$(basename "$backup")${RESET}"
  fi

  mkdir -p "$conf_dir"
  _alacritty_conf_content > "$conf_file"
  info "Wrote ${conf_file}"
}


# Returns 0 if the zsh completions eval line is already present in $1.
_zshrc_has_completions() {
  grep -qF "kdev --completions zsh" "$1" 2>/dev/null
}

# Append the eval line to ~/.zshrc if not already there.
# Prints to stdout whether it was added or was already present.
# Returns 0 in both cases; sets caller's _zshrc_modified=true when it writes.
_append_zsh_completions() {
  local zshrc="$HOME/.zshrc"

  if _zshrc_has_completions "$zshrc"; then
    dim "  [up to date]  zsh completions in ~/.zshrc"
    return 0
  fi

  {
    echo ""
    echo "# kdev shell completions"
    echo 'eval "$(kdev --completions zsh)"'
  } >> "$zshrc"

  info "Added shell completions to ~/.zshrc"
  _zshrc_modified=true
}

_install_lf_config() {
  local lf_src
  lf_src="$(dirname "$(_script_path)")/.config/lf"

  if [[ ! -d "$lf_src" ]]; then
    warn "lf config not found at ${lf_src} — skipping."
    return 0
  fi

  local lf_dest="$HOME/.config/lf"

  # Back up existing config only if it wasn't deployed by kdev
  if [[ -d "$lf_dest" ]] && ! grep -qF "managed by kdev" "$lf_dest/lfrc" 2>/dev/null; then
    local backup="${lf_dest}.bak"
    local n=1
    while [[ -d "$backup" ]]; do
      backup="${lf_dest}.bak${n}"
      ((n++))
    done
    mv "$lf_dest" "$backup"
    step "Backed up ${DIM}~/.config/lf${RESET} → ${DIM}$(basename "$backup")${RESET}"
  fi

  mkdir -p "$lf_dest"
  cp "$lf_src/lfrc"  "$lf_dest/lfrc"
  cp "$lf_src/scope" "$lf_dest/scope"
  cp "$lf_src/icons" "$lf_dest/icons"
  chmod +x "$lf_dest/scope"
  info "Installed lf config → ${lf_dest}"
}

_install_tmux_resurrect() {
  local plugin_dir="$HOME/.config/tmux/plugins/tmux-resurrect"

  if [[ -d "$plugin_dir" ]]; then
    dim "  [installed]  tmux-resurrect"
    return 0
  fi

  step "Installing ${CYAN}tmux-resurrect${RESET}..."
  mkdir -p "$(dirname "$plugin_dir")"
  git clone --quiet https://github.com/tmux-plugins/tmux-resurrect "$plugin_dir"
  info "tmux-resurrect installed → ${plugin_dir}"
}

# Copy skills/ from the kdev repo into ~/.agents/skills/.
# Each skill is a subdirectory containing SKILL.md. Existing skills with the
# same name are overwritten so updates are picked up on re-run.
_install_skills() {
  local skills_src
  skills_src="$(dirname "$(_script_path)")/skills"

  if [[ ! -d "$skills_src" ]]; then
    warn "skills/ directory not found next to kdev — skipping."
    return 0
  fi

  local dest="$HOME/.agents/skills"
  mkdir -p "$dest"

  local dir name copied=0
  for dir in "$skills_src"/*/; do
    [[ -d "$dir" ]] || continue
    name="$(basename "$dir")"
    cp -R "$dir" "$dest/$name"
    ((copied++)) || true
  done

  if [[ $copied -gt 0 ]]; then
    info "Installed $copied skill(s) → ${dest}"
  else
    dim "  No skills found in ${skills_src}"
  fi
}

_install_global_agents_md() {
  local src
  src="$(dirname "$(_script_path)")/global-agents.md"

  if [[ ! -f "$src" ]]; then
    warn "global-agents.md not found next to kdev — skipping."
    return 0
  fi

  local dest_dir="$HOME/.pi/agent"
  local dest="$dest_dir/AGENTS.md"
  mkdir -p "$dest_dir"
  cp "$src" "$dest"
  info "Installed global AGENTS.md → ${dest}"
}

# ─── Subcommand: setup ───────────────────────────────────────────────────────

cmd_setup() {
  local plan_only=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --plan)    plan_only=true ;;
      --help|-h) usage_setup; exit 0 ;;
      -*) die "Unknown option: $1." ;;
      *)  die "Unexpected argument: $1." ;;
    esac
    shift
  done

  echo ""
  echo -e "${BOLD}${SCRIPT_NAME} setup${RESET}$( $plan_only && echo " ${DIM}(dry run)${RESET}" || true)"
  echo ""

  if $plan_only; then
    echo -e "${BOLD}Tools:${RESET}"
    local tools=(
      "alacritty:alacritty:cask"
      "tmux:tmux:formula"
      "neovim:nvim:formula"
      "lazygit:lazygit:formula"
      "lf:lf:formula"
      "bat:bat:formula"
      "git:git:formula"
      "node:npm:formula"
    )
    local entry name binary kind
    for entry in "${tools[@]}"; do
      name="${entry%%:*}"; entry="${entry#*:}"
      binary="${entry%%:*}"; kind="${entry#*:}"
      if command -v "$binary" &>/dev/null; then
        echo -e "  ${DIM}[installed]${RESET}       $name"
      else
        echo -e "  [would install]  $name ($kind)"
      fi
    done
    if command -v pi &>/dev/null; then
      echo -e "  ${DIM}[installed]${RESET}       pi-coding-agent"
    else
      echo -e "  [would install]  pi-coding-agent (npm)"
    fi

    echo ""
    echo -e "${BOLD}Configs:${RESET}"

    if [[ -f "$HOME/.tmux.conf" ]]; then
      echo "  [would back up]     ~/.tmux.conf → ~/.tmux.conf.bak"
    fi
    if [[ -f "$HOME/.config/tmux/tmux.conf" ]]; then
      echo "  [would overwrite]   ~/.config/tmux/tmux.conf"
    else
      echo "  [would create]      ~/.config/tmux/tmux.conf"
    fi

    local alacritty_conf="$HOME/.config/alacritty/alacritty.toml"
    if [[ -f "$alacritty_conf" ]] && grep -qF "generated by kdev" "$alacritty_conf"; then
      echo -e "  ${DIM}[up to date]${RESET}        alacritty.toml"
    elif [[ -f "$alacritty_conf" ]]; then
      echo "  [would back up]     alacritty.toml → alacritty.toml.bak"
      echo "  [would create]      ~/.config/alacritty/alacritty.toml"
    else
      echo "  [would create]      ~/.config/alacritty/alacritty.toml"
    fi

    if [[ -d "$HOME/.config/tmux/plugins/tmux-resurrect" ]]; then
      echo -e "  ${DIM}[installed]${RESET}         tmux-resurrect"
    else
      echo "  [would install]     tmux-resurrect plugin"
    fi

    local zshrc="$HOME/.zshrc"
    if _zshrc_has_completions "$zshrc"; then
      echo -e "  ${DIM}[up to date]${RESET}        zsh completions in ~/.zshrc"
    elif [[ -f "$zshrc" ]]; then
      echo "  [would append]      zsh completions eval to ~/.zshrc"
    else
      echo "  [not found]         ~/.zshrc — will skip completions"
    fi

    local lf_dest="$HOME/.config/lf"
    if [[ -f "$lf_dest/lfrc" ]] && grep -qF "managed by kdev" "$lf_dest/lfrc" 2>/dev/null; then
      echo -e "  ${DIM}[up to date]${RESET}        lf config"
    elif [[ -d "$lf_dest" ]]; then
      echo "  [would back up]     ~/.config/lf → ~/.config/lf.bak"
      echo "  [would install]     lf config → ~/.config/lf"
    else
      echo "  [would install]     lf config → ~/.config/lf"
    fi

    local skills_src
    skills_src="$(dirname "$(_script_path)")/skills"
    local skills_dest="$HOME/.agents/skills"
    if [[ -d "$skills_src" ]]; then
      local skill_count=0 sdir
      for sdir in "$skills_src"/*/; do
        [[ -d "$sdir" ]] && ((skill_count++)) || true
      done
      if [[ $skill_count -gt 0 ]]; then
        echo "  [would install]     $skill_count skill(s) → ~/.agents/skills/"
      fi
    else
      echo -e "  ${DIM}[not found]${RESET}         skills/ directory"
    fi

    local agents_src
    agents_src="$(dirname "$(_script_path)")/global-agents.md"
    local agents_dest="$HOME/.pi/agent/AGENTS.md"
    if [[ -f "$agents_src" ]]; then
      if [[ -f "$agents_dest" ]] && diff -q "$agents_src" "$agents_dest" &>/dev/null; then
        echo -e "  ${DIM}[up to date]${RESET}        global AGENTS.md"
      else
        echo "  [would install]     global AGENTS.md → ~/.pi/agent/AGENTS.md"
      fi
    else
      echo -e "  ${DIM}[not found]${RESET}         global-agents.md"
    fi

    echo ""
    if command -v "$SCRIPT_NAME" &>/dev/null; then
      echo -e "  ${DIM}[in PATH]${RESET}           $SCRIPT_NAME → $(command -v "$SCRIPT_NAME")"
    else
      echo "  [would ask]         symlink $SCRIPT_NAME into ~/.local/bin/"
    fi

    return 0
  fi

  _check_brew

  echo -e "${BOLD}Tools:${RESET}"
  _install_brew_cask alacritty
  _install_brew_formula tmux
  _install_brew_formula neovim nvim
  _install_brew_formula lazygit
  _install_brew_formula lf
  _install_brew_formula bat
  _install_brew_formula git
  _install_brew_formula node npm
  _install_pi_agent

  echo ""
  echo -e "${BOLD}Configs:${RESET}"
  _write_tmux_conf
  _write_alacritty_conf
  _install_tmux_resurrect
  local _zshrc_modified=false
  _append_zsh_completions
  _install_lf_config
  _install_skills
  _install_global_agents_md

  # Offer to symlink into PATH
  echo ""
  if command -v "$SCRIPT_NAME" &>/dev/null; then
    dim "  [in PATH]  $SCRIPT_NAME → $(command -v "$SCRIPT_NAME")"
  else
    if _confirm "  Add ${BOLD}${SCRIPT_NAME}${RESET} to PATH via ~/.local/bin symlink?"; then
      local script_real target_dir target
      script_real="$(_script_path)"
      target_dir="$HOME/.local/bin"
      target="$target_dir/$SCRIPT_NAME"
      mkdir -p "$target_dir"
      ln -sf "$script_real" "$target"
      info "Symlinked ${target} → ${script_real}"
      # Check if ~/.local/bin is in PATH
      if [[ ":$PATH:" != *":$target_dir:"* ]]; then
        warn "~/.local/bin is not in your PATH."
        dim "  Add to ~/.zshrc:  export PATH=\"\$HOME/.local/bin:\$PATH\""
      fi
    else
      dim "  Skipped symlink. Run manually:"
      dim "    ln -s $(_script_path) ~/.local/bin/$SCRIPT_NAME"
    fi
  fi

  echo ""
  info "Setup complete."
  dim "  Reload tmux config:  tmux source-file ~/.config/tmux/tmux.conf"
  if [[ "$_zshrc_modified" == true ]]; then
    dim "  ~/.zshrc was modified — run: source ~/.zshrc"
  fi
}

# ─── Layout ───────────────────────────────────────────────────────────────────

# Create the 3-pane dev layout in an existing tmux window.
#
# ┌──────────────────┬──────────────────┐
# │                  │    lazygit       │
# │    pi agent      │   (top-right)    │
# │    (left, 50%)   ├──────────────────┤
# │                  │    lf            │
# │                  │  (bottom-right)  │
# └──────────────────┴──────────────────┘
_setup_dev_layout() {
  local session="$1" window="$2" dir="$3"

  local quoted_dir
  printf -v quoted_dir '%q' "$dir"

  local agent_cmd
  if command -v pi &>/dev/null; then
    agent_cmd="cd $quoted_dir && pi"
  else
    warn "pi-coding-agent not found — using shell. Install: npm i -g @mariozechner/pi-coding-agent"
    agent_cmd="cd $quoted_dir"
  fi

  # Pane 1 (left): already exists — coding agent
  local p1
  p1="$(tmux list-panes -t "$session:$window" -F '#{pane_id}' | head -1)"
  tmux send-keys -t "$p1" "$agent_cmd" Enter
  tmux select-pane -t "$p1" -T "agent"

  # Pane 2 (top-right): horizontal split — lazygit
  local p2
  p2="$(tmux split-window -t "$session:$window" -h -p 50 \
         -c "$dir" -P -F '#{pane_id}')"
  tmux send-keys -t "$p2" "lazygit" Enter
  tmux select-pane -t "$p2" -T "lazygit"

  # Pane 3 (bottom-right): vertical split of p2 — lf file manager
  local p3
  p3="$(tmux split-window -t "$p2" -v -p 65 \
         -c "$dir" -P -F '#{pane_id}')"
  tmux send-keys -t "$p3" "lf" Enter
  tmux select-pane -t "$p3" -T "lf"

  # Focus the agent pane
  tmux select-pane -t "$p1"
}

# ─── Session launcher ────────────────────────────────────────────────────────

# Shared logic for dev and launch: create tmux session/window with layout,
# or switch to it if it already exists.
_launch_session() {
  local repo_root="$1" name="$2" wt_dir="$3"

  command -v tmux &>/dev/null || die "tmux not found. Run: ${CYAN}$SCRIPT_NAME setup${RESET}"

  local session_name window_name
  session_name="$(_tmux_session_name "$(basename "$repo_root")")"
  window_name="$name"

  if tmux has-session -t "$session_name" 2>/dev/null; then
    if tmux list-windows -t "$session_name" -F '#{window_name}' 2>/dev/null \
         | grep -qx "$window_name"; then
      info "Switching to ${BOLD}${session_name}:${window_name}${RESET}"
    else
      tmux new-window -t "$session_name:" -n "$window_name" -c "$wt_dir"
      _setup_dev_layout "$session_name" "$window_name" "$wt_dir"
      info "Created window ${BOLD}${session_name}:${window_name}${RESET}"
    fi
  else
    tmux new-session -d -s "$session_name" -n "$window_name" -c "$wt_dir" \
         -x 220 -y 50
    _setup_dev_layout "$session_name" "$window_name" "$wt_dir"
    info "Started session ${BOLD}${session_name}${RESET} window ${BOLD}${window_name}${RESET}"
  fi

  # Ensure kdev tmux config is active on the running server — covers servers
  # started before `kdev setup` wrote the config.
  local _kdev_conf="$HOME/.config/tmux/tmux.conf"
  if [[ -f "$_kdev_conf" ]]; then
    tmux source-file "$_kdev_conf" 2>/dev/null || true
  fi

  tmux select-window -t "$session_name:$window_name"
  _tmux_attach_or_switch "$session_name"
}

# ─── Subcommand: dev ─────────────────────────────────────────────────────────

cmd_dev() {
  local name="" from_ref=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h) usage_dev; exit 0 ;;
      --from)
        shift
        [[ $# -eq 0 ]] && die "--from requires a ref."
        from_ref="$1"
        ;;
      -*) die "Unknown option: $1." ;;
      *)
        [[ -n "$name" ]] && die "Too many arguments."
        name="$1"
        ;;
    esac
    shift
  done

  [[ -z "$name" ]] && die "Usage: $SCRIPT_NAME dev <name> [--from <ref>]"

  if ! git check-ref-format --branch "$name" &>/dev/null; then
    die "Invalid name: '$name'. Must be a valid git branch name."
  fi

  local repo_root
  repo_root="$(_find_repo_root)" || die "Not inside a git repository.\n  Run this command from within a git repo."

  local wt_dir="$repo_root/$WORKTREES_DIR/$name"

  # Fetch and warn about stale default branch before creating new worktree
  if [[ ! -d "$wt_dir" || ! $(_git_worktree_valid "$wt_dir" 2>/dev/null) ]] \
     && [[ -z "$from_ref" ]]; then
    _git_fetch_and_check "$repo_root" || return 1
  fi

  # Create worktree if it doesn't exist; repair if git link is broken
  if [[ ! -d "$wt_dir" ]]; then
    mkdir -p "$repo_root/$WORKTREES_DIR"
    _ensure_gitignore "$repo_root" "$WORKTREES_DIR"

    if [[ -z "$from_ref" ]]; then
      from_ref="$(_git_default_branch "$repo_root")" || from_ref="HEAD"
    fi

    # Validate the from-ref
    if [[ "$from_ref" != "HEAD" ]]; then
      git -C "$repo_root" rev-parse --verify "${from_ref}^{commit}" &>/dev/null ||
        die "Ref '$from_ref' does not exist."
    fi

    if git -C "$repo_root" show-ref --verify --quiet "refs/heads/$name" 2>/dev/null; then
      # Branch already exists — create worktree on existing branch
      step "Creating worktree ${BOLD}${name}${RESET} (existing branch)..."
      git -C "$repo_root" worktree add "$wt_dir" "$name" --quiet ||
        die "Failed to create worktree. Is branch '$name' already checked out?"
    else
      step "Creating worktree ${BOLD}${name}${RESET} from ${CYAN}${from_ref}${RESET}..."
      git -C "$repo_root" worktree add "$wt_dir" -b "$name" "$from_ref" --quiet ||
        die "Failed to create worktree."
    fi

    info "Worktree ${BOLD}${name}${RESET} → branch ${CYAN}${name}${RESET}"

  elif ! _git_worktree_valid "$wt_dir"; then
    # Directory exists but git link is broken (e.g. repo was renamed/moved).
    # Remove the orphaned directory first so `git worktree prune` sees it gone
    # and drops the stale registration — otherwise `worktree add` would refuse
    # to reuse the branch that's still "checked out" in the phantom worktree.
    warn "Worktree '${name}' has a broken git link — repairing..."
    rm -rf "$wt_dir"
    git -C "$repo_root" worktree prune 2>/dev/null || true
    mkdir -p "$repo_root/$WORKTREES_DIR"

    if git -C "$repo_root" show-ref --verify --quiet "refs/heads/$name" 2>/dev/null; then
      # Branch survived the rename — reattach to it
      step "Re-creating worktree ${BOLD}${name}${RESET} (existing branch)..."
      git -C "$repo_root" worktree add "$wt_dir" "$name" --quiet ||
        die "Failed to recreate worktree."
    else
      if [[ -z "$from_ref" ]]; then
        from_ref="$(_git_default_branch "$repo_root")" || from_ref="HEAD"
      fi
      if [[ "$from_ref" != "HEAD" ]]; then
        git -C "$repo_root" rev-parse --verify "${from_ref}^{commit}" &>/dev/null ||
          die "Ref '$from_ref' does not exist."
      fi
      step "Re-creating worktree ${BOLD}${name}${RESET} from ${CYAN}${from_ref}${RESET}..."
      git -C "$repo_root" worktree add "$wt_dir" -b "$name" "$from_ref" --quiet ||
        die "Failed to recreate worktree."
    fi

    info "Repaired worktree ${BOLD}${name}${RESET} → branch ${CYAN}${name}${RESET}"

  else
    dim "Worktree ${name} already exists"
  fi

  _launch_session "$repo_root" "$name" "$wt_dir"
}

# ─── Subcommand: launch ──────────────────────────────────────────────────────

cmd_launch() {
  local name=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h) usage_launch; exit 0 ;;
      -*) die "Unknown option: $1." ;;
      *)
        [[ -n "$name" ]] && die "Too many arguments."
        name="$1"
        ;;
    esac
    shift
  done

  [[ -z "$name" ]] && die "Usage: $SCRIPT_NAME launch <name>"

  local repo_root
  repo_root="$(_find_repo_root)" || die "Not inside a git repository."

  local wt_dir="$repo_root/$WORKTREES_DIR/$name"
  [[ ! -d "$wt_dir" ]] && die "Worktree '$name' does not exist.\n  Create it with: ${CYAN}$SCRIPT_NAME dev $name${RESET}"
  ! _git_worktree_valid "$wt_dir" && die "Worktree '$name' has a broken git link.\n  Run ${CYAN}$SCRIPT_NAME dev $name${RESET} to repair it."

  _launch_session "$repo_root" "$name" "$wt_dir"
}

# ─── Subcommand: list ────────────────────────────────────────────────────────

cmd_list() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h) usage_list; exit 0 ;;
      -*) die "Unknown option: $1." ;;
      *)  die "Unexpected argument: $1." ;;
    esac
    shift
  done

  local repo_root
  repo_root="$(_find_repo_root)" || die "Not inside a git repository."

  local wt_base="$repo_root/$WORKTREES_DIR"
  local session_name
  session_name="$(_tmux_session_name "$(basename "$repo_root")")"

  if [[ ! -d "$wt_base" ]] || [[ -z "$(ls -A "$wt_base" 2>/dev/null)" ]]; then
    echo ""
    echo -e "  No worktrees found. Create one with: ${CYAN}$SCRIPT_NAME dev <name>${RESET}"
    return 0
  fi

  # Gather tmux window names
  local -a tmux_windows=()
  if command -v tmux &>/dev/null && tmux has-session -t "$session_name" 2>/dev/null; then
    while IFS= read -r win; do
      tmux_windows+=("$win")
    done < <(tmux list-windows -t "$session_name" -F '#{window_name}:#{window_active}' 2>/dev/null)
  fi

  echo ""
  echo -e "  ${BOLD}$(basename "$repo_root")${RESET} worktrees:  ${DIM}(session: ${session_name})${RESET}"
  echo ""
  printf "  ${DIM}%-20s %-20s %-10s %-10s${RESET}\n" "NAME" "BRANCH" "STATUS" "TMUX"
  printf "  ${DIM}%-20s %-20s %-10s %-10s${RESET}\n" "────" "──────" "──────" "────"

  local dir name branch status window_status
  for dir in "$wt_base"/*/; do
    [[ -d "$dir" ]] || continue
    name="$(basename "$dir")"

    if ! _git_worktree_valid "$dir"; then
      printf "  %-20s %-20s %-21b %-21b\n" "$name" "?" "${RED}broken${RESET}" "${DIM}none${RESET}"
      continue
    fi

    branch="$(git -C "$dir" rev-parse --abbrev-ref HEAD 2>/dev/null)" || branch="?"

    if _git_is_dirty "$dir"; then
      status="${YELLOW}dirty${RESET}"
    else
      status="${GREEN}clean${RESET}"
    fi

    window_status="${DIM}none${RESET}"
    local win_entry
    for win_entry in "${tmux_windows[@]+"${tmux_windows[@]}"}"; do
      local wn="${win_entry%%:*}" wa="${win_entry##*:}"
      if [[ "$wn" == "$name" ]]; then
        if [[ "$wa" == "1" ]]; then
          window_status="${CYAN}active${RESET}"
        else
          window_status="open"
        fi
        break
      fi
    done

    printf "  %-20s %-20s %-21b %-21b\n" "$name" "$branch" "$status" "$window_status"
  done
  echo ""
}

# ─── Subcommand: delete ──────────────────────────────────────────────────────

cmd_delete() {
  local name="" force=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h) usage_delete; exit 0 ;;
      --force|-f) force=true ;;
      -*) die "Unknown option: $1." ;;
      *)
        [[ -n "$name" ]] && die "Too many arguments."
        name="$1"
        ;;
    esac
    shift
  done

  [[ -z "$name" ]] && die "Usage: $SCRIPT_NAME delete <name> [--force]"

  local repo_root
  repo_root="$(_find_repo_root)" || die "Not inside a git repository."

  local wt_dir="$repo_root/$WORKTREES_DIR/$name"
  [[ ! -d "$wt_dir" ]] && die "Worktree '$name' does not exist."

  # Capture validity before any removal — used later to skip git worktree remove
  # and to fall back to $name for branch deletion when git can't read the worktree.
  local wt_valid=true
  _git_worktree_valid "$wt_dir" || wt_valid=false

  local session_name
  session_name="$(_tmux_session_name "$(basename "$repo_root")")"

  # Kill tmux window if open
  if command -v tmux &>/dev/null && tmux has-session -t "$session_name" 2>/dev/null; then
    if tmux list-windows -t "$session_name" -F '#{window_name}' 2>/dev/null \
         | grep -qx "$name"; then
      if [[ "$force" != true ]]; then
        die "tmux window '${name}' is still open.\n  Close it first, or use ${CYAN}--force${RESET}."
      fi
      step "Killing tmux window ${BOLD}${session_name}:${name}${RESET}..."
      tmux kill-window -t "$session_name:$name" 2>/dev/null || true
    fi
  fi

  # Check for uncommitted changes (only meaningful when git link is intact)
  if [[ "$force" != true ]] && [[ "$wt_valid" == true ]] && _git_is_dirty "$wt_dir"; then
    die "Worktree '$name' has uncommitted changes.\n  Commit or stash them, or use ${CYAN}--force${RESET}."
  fi

  local branch_name
  branch_name="$(git -C "$wt_dir" rev-parse --abbrev-ref HEAD 2>/dev/null)" || true
  # For broken worktrees git can't read the branch; fall back to the worktree name
  # (kdev always names the branch after the worktree, so this is safe).
  [[ -z "${branch_name:-}" ]] && branch_name="$name"

  step "Removing worktree ${BOLD}${name}${RESET}..."
  if [[ "$wt_valid" == false ]] || [[ "$force" == true ]]; then
    # git worktree remove requires a live git link; skip it for broken worktrees
    git -C "$repo_root" worktree remove --force "$wt_dir" 2>/dev/null ||
      rm -rf "$wt_dir"
  else
    git -C "$repo_root" worktree remove "$wt_dir"
  fi

  git -C "$repo_root" worktree prune --quiet 2>/dev/null || true

  # Only delete the branch when it matches the worktree name
  if [[ -n "${branch_name:-}" && "$branch_name" == "$name" && "$branch_name" != "HEAD" ]]; then
    if git -C "$repo_root" branch -d "$branch_name" &>/dev/null; then
      dim "  Deleted branch $branch_name"
    elif [[ "$force" == true ]]; then
      git -C "$repo_root" branch -D "$branch_name" &>/dev/null &&
        dim "  Force-deleted branch $branch_name"
    fi
  fi

  info "Removed ${BOLD}${name}${RESET}"
}

