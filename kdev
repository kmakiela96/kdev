    fi

    local lf_dest="$HOME/.config/lf"
    if [[ -f "$lf_dest/lfrc" ]] && grep -qF "managed by kdev" "$lf_dest/lfrc" 2>/dev/null; then
      echo -e "  ${DIM}[up to date]${RESET}        lf config"
    elif [[ -d "$lf_dest" ]]; then
      echo "  [would back up]     ~/.config/lf → ~/.config/lf.bak"
      echo "  [would install]     lf config → ~/.config/lf"
    else
      echo "  [would install]     lf config → ~/.config/lf"
    fi

    local nvim_dest="$HOME/.config/nvim"
    if [[ -f "$nvim_dest/init.lua" ]] && grep -qF "managed by kdev" "$nvim_dest/init.lua" 2>/dev/null; then
      echo -e "  ${DIM}[up to date]${RESET}        nvim config"
    elif [[ -d "$nvim_dest" ]]; then
      echo "  [would back up]     ~/.config/nvim → ~/.config/nvim.bak"
      echo "  [would install]     nvim config → ~/.config/nvim"
    else
      echo "  [would install]     nvim config → ~/.config/nvim"
    fi

    local lazygit_src
    lazygit_src="$(dirname "$(_script_path)")/.config/lazygit/config.yml"
    local lazygit_conf="$HOME/.config/lazygit/config.yml"
    if [[ -f "$lazygit_conf" ]] && diff -q "$lazygit_src" "$lazygit_conf" &>/dev/null; then
      echo -e "  ${DIM}[up to date]${RESET}        lazygit config → ~/.config/lazygit/config.yml"
    elif [[ -f "$lazygit_conf" ]] && ! grep -qF "managed by kdev" "$lazygit_conf"; then
      echo "  [would back up]     lazygit config.yml → config.yml.bak"
      echo "  [would create]      lazygit config → ~/.config/lazygit/config.yml"
    else
      echo "  [would create]      lazygit config → ~/.config/lazygit/config.yml"
    fi

    local skills_src
    skills_src="$(dirname "$(_script_path)")/skills"
    local skills_dest="$HOME/.agents/skills"
    if [[ -d "$skills_src" ]]; then
      local skill_count=0 skill_new=0 sdir sname
      for sdir in "$skills_src"/*/; do
        [[ -d "$sdir" ]] || continue
        ((skill_count++)) || true
        sname="$(basename "$sdir")"
        if ! diff -rq "$sdir" "$skills_dest/$sname" &>/dev/null; then
          ((skill_new++)) || true
        fi
      done
      if [[ $skill_count -gt 0 ]]; then
        if [[ $skill_new -eq 0 ]]; then
          echo -e "  ${DIM}[up to date]${RESET}        $skill_count skill(s)"
        else
          echo "  [would install]     $skill_new/$skill_count skill(s) → ~/.agents/skills/"
        fi
      fi
    else
