#!/usr/bin/env bash
set -euo pipefail

readonly SCRIPT_NAME="kdev"
readonly VERSION="2.9.0"
readonly WORKTREES_DIR=".worktrees"

# ─── Colors ───────────────────────────────────────────────────────────────────

if [[ -t 1 ]]; then
  BOLD=$'\033[1m'
  DIM=$'\033[2m'
  RED=$'\033[0;31m'
  GREEN=$'\033[0;32m'
  YELLOW=$'\033[0;33m'
  CYAN=$'\033[0;36m'
  RESET=$'\033[0m'
else
  BOLD='' DIM='' RED='' GREEN='' YELLOW='' CYAN='' RESET=''
fi

# ─── Helpers ──────────────────────────────────────────────────────────────────

die()  { echo -e "${RED}error:${RESET} $*" >&2; exit 1; }
_err() { echo -e "${RED}error:${RESET} $*" >&2; }
warn() { echo -e "${YELLOW}warn:${RESET} $*" >&2; }
info() { echo -e "${GREEN}✓${RESET} $*"; }
dim()  { echo -e "${DIM}$*${RESET}"; }
step() { echo -e "  $*"; }

# Ask a yes/no question. Default is no. Returns 0 for yes, 1 for no.
_confirm() {
  local answer
  printf "%s [y/N]: " "$1"
  read -r answer
  [[ "$answer" =~ ^[Yy]$ ]]
}

# Resolve the absolute path of this script, following symlinks.
_script_path() {
  local src="${BASH_SOURCE[0]:-$0}"
  local real
  real="$(readlink -f "$src" 2>/dev/null)" || real="$src"
  echo "$real"
}

# ─── Git helpers ──────────────────────────────────────────────────────────────

# Find the root of the main repo, even when called from inside a worktree
# created by this tool (.worktrees/<name>/).
_find_repo_root() {
  local toplevel
  toplevel="$(git rev-parse --show-toplevel 2>/dev/null)" || return 1

  local parent_dir parent_name
  parent_dir="$(dirname "$toplevel")"
  parent_name="$(basename "$parent_dir")"

  if [[ "$parent_name" == "$WORKTREES_DIR" ]]; then
    # Inside .worktrees/<name> — repo root is two levels up
    dirname "$parent_dir"
  else
    echo "$toplevel"
  fi
}

# Detect the default branch (main or master). Tries origin/HEAD first,
# then checks for common local branch names.
_git_default_branch() {
  local repo="$1"
  local remote_head
  remote_head="$(git -C "$repo" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null)" && {
    echo "${remote_head#refs/remotes/origin/}"
    return 0
  }
  local branch
  for branch in main master; do
    if git -C "$repo" show-ref --verify --quiet "refs/heads/$branch" 2>/dev/null; then
      echo "$branch"
      return 0
    fi
  done
  return 1
}

_git_is_dirty() {
  git -C "$1" status --porcelain 2>/dev/null | grep -q .
}

# Fetch origin and warn if default branch is behind remote.
# Returns 0 (proceed) or 1 (user aborted).
_git_fetch_and_check() {
  local repo="$1"
  local default_branch
  default_branch="$(_git_default_branch "$repo")" || return 0

  # No remote → nothing to check
  git -C "$repo" remote | grep -q . || return 0

  step "Fetching origin..."
  git -C "$repo" fetch origin --quiet 2>/dev/null || {
    warn "Failed to fetch origin — continuing with local state."
    return 0
  }

  # Check if remote tracking branch exists
  local remote_ref="refs/remotes/origin/${default_branch}"
  git -C "$repo" show-ref --verify --quiet "$remote_ref" 2>/dev/null || return 0

  local local_rev remote_rev
  local_rev="$(git -C "$repo" rev-parse "refs/heads/${default_branch}" 2>/dev/null)" || return 0
  remote_rev="$(git -C "$repo" rev-parse "$remote_ref" 2>/dev/null)" || return 0

  if [[ "$local_rev" == "$remote_rev" ]]; then
    return 0
  fi

  local behind
  behind="$(git -C "$repo" rev-list --count "refs/heads/${default_branch}..${remote_ref}" 2>/dev/null)" || behind=0

  if [[ "$behind" -gt 0 ]]; then
    warn "Local ${BOLD}${default_branch}${RESET} is ${BOLD}${behind}${RESET} commit(s) behind ${BOLD}origin/${default_branch}${RESET}."
    if ! _confirm "  Continue creating worktree from local ${default_branch}?"; then
      _err "Aborted. Pull ${default_branch} first: git checkout ${default_branch} && git pull"
      return 1
    fi
  fi
  return 0
}

# Returns 0 if the directory is a functioning git worktree (git link resolves).
# A broken worktree has a .git file pointing at a path that no longer exists
# (e.g. after the main repo was renamed/moved).
_git_worktree_valid() {
  git -C "$1" rev-parse --git-dir &>/dev/null
}

# Add an entry to .gitignore if not already present.
_ensure_gitignore() {
  local root="$1" entry="$2"
  local gitignore="$root/.gitignore"

  if [[ -f "$gitignore" ]] && grep -qxF "$entry" "$gitignore"; then
    return 0
  fi

  echo "$entry" >> "$gitignore"
}

# ─── tmux helpers ─────────────────────────────────────────────────────────────

# Sanitize a name for use as a tmux session name. tmux interprets dots and
# colons specially in target strings, so replace them with underscores.
_tmux_session_name() {
  local name="$1"
  name="${name//./_}"
  name="${name//:/_}"
  echo "$name"
}

_tmux_attach_or_switch() {
  local session="$1"
  if [[ -n "${KDEV_TEST_NO_ATTACH:-}" ]]; then
    return 0
  fi
  if [[ -n "${TMUX:-}" ]]; then
    tmux switch-client -t "$session"
  else
    tmux attach -t "$session"
  fi
}

