#!/usr/bin/env bash
set -euo pipefail

readonly SCRIPT_NAME="kdev"
readonly VERSION="2.0.0"
readonly WORKTREES_DIR=".worktrees"

# ─── Colors ───────────────────────────────────────────────────────────────────

if [[ -t 1 ]]; then
  BOLD=$'\033[1m'
  DIM=$'\033[2m'
  RED=$'\033[0;31m'
  GREEN=$'\033[0;32m'
  YELLOW=$'\033[0;33m'
  CYAN=$'\033[0;36m'
  RESET=$'\033[0m'
else
  BOLD='' DIM='' RED='' GREEN='' YELLOW='' CYAN='' RESET=''
fi

# ─── Helpers ──────────────────────────────────────────────────────────────────

die()  { echo -e "${RED}error:${RESET} $*" >&2; exit 1; }
_err() { echo -e "${RED}error:${RESET} $*" >&2; }
warn() { echo -e "${YELLOW}warn:${RESET} $*" >&2; }
info() { echo -e "${GREEN}✓${RESET} $*"; }
dim()  { echo -e "${DIM}$*${RESET}"; }
step() { echo -e "  $*"; }

# Ask a yes/no question. Default is no. Returns 0 for yes, 1 for no.
_confirm() {
  local answer
  printf "%s [y/N]: " "$1"
  read -r answer
  [[ "$answer" =~ ^[Yy]$ ]]
}

# Resolve the absolute path of this script, following symlinks.
_script_path() {
  local src="${BASH_SOURCE[0]:-$0}"
  local real
  real="$(readlink -f "$src" 2>/dev/null)" || real="$src"
  echo "$real"
}

# ─── Git helpers ──────────────────────────────────────────────────────────────

# Find the root of the main repo, even when called from inside a worktree
# created by this tool (.worktrees/<name>/).
_find_repo_root() {
  local toplevel
  toplevel="$(git rev-parse --show-toplevel 2>/dev/null)" || return 1

  local parent_dir parent_name
  parent_dir="$(dirname "$toplevel")"
  parent_name="$(basename "$parent_dir")"

  if [[ "$parent_name" == "$WORKTREES_DIR" ]]; then
    # Inside .worktrees/<name> — repo root is two levels up
    dirname "$parent_dir"
  else
    echo "$toplevel"
  fi
}

# Detect the default branch (main or master). Tries origin/HEAD first,
# then checks for common local branch names.
_git_default_branch() {
  local repo="$1"
  local remote_head
  remote_head="$(git -C "$repo" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null)" && {
    echo "${remote_head#refs/remotes/origin/}"
    return 0
  }
  local branch
  for branch in main master; do
    if git -C "$repo" show-ref --verify --quiet "refs/heads/$branch" 2>/dev/null; then
      echo "$branch"
      return 0
    fi
  done
  return 1
}

_git_is_dirty() {
  git -C "$1" status --porcelain 2>/dev/null | grep -q .
}

# Add an entry to .gitignore if not already present.
_ensure_gitignore() {
  local root="$1" entry="$2"
  local gitignore="$root/.gitignore"

  if [[ -f "$gitignore" ]] && grep -qxF "$entry" "$gitignore"; then
    return 0
  fi

  echo "$entry" >> "$gitignore"
}

# ─── tmux helpers ─────────────────────────────────────────────────────────────

# Sanitize a name for use as a tmux session name. tmux interprets dots and
# colons specially in target strings, so replace them with underscores.
_tmux_session_name() {
  local name="$1"
  name="${name//./_}"
  name="${name//:/_}"
  echo "$name"
}

_tmux_attach_or_switch() {
  local session="$1"
  if [[ -n "${KDEV_TEST_NO_ATTACH:-}" ]]; then
    return 0
  fi
  if [[ -n "${TMUX:-}" ]]; then
    tmux switch-client -t "$session"
  else
    tmux attach -t "$session"
  fi
}

# ─── Config content generators ────────────────────────────────────────────────

_tmux_conf_content() {
  cat <<'TMUX_CONF'
# ~/.config/tmux/tmux.conf — generated by kdev

# ─── Terminal ─────────────────────────────────────────
set -g default-terminal "tmux-256color"
set -ag terminal-overrides ",alacritty:RGB"

# ─── General ──────────────────────────────────────────
set -g mouse on
set -g base-index 1
setw -g pane-base-index 1
set -g history-limit 50000
set -g escape-time 0
set -g focus-events on
set -g renumber-windows on

# ─── Prefix: Ctrl-a ──────────────────────────────────
set -g prefix C-a
unbind C-b
bind C-a send-prefix

# ─── Splits (in current path) ────────────────────────
bind | split-window -h -c "#{pane_current_path}"
bind - split-window -v -c "#{pane_current_path}"
unbind '"'
unbind %

# ─── Pane navigation (Option+hjkl → M-hjkl) ──────────
bind -n M-h select-pane -L
bind -n M-j select-pane -D
bind -n M-k select-pane -U
bind -n M-l select-pane -R

# ─── Pane swap (Option+Shift+HJKL → M-HJKL) ─────────
bind -n M-H swap-pane -d -t '{left-of}'
bind -n M-J swap-pane -d -t '{down-of}'
bind -n M-K swap-pane -d -t '{up-of}'
bind -n M-L swap-pane -d -t '{right-of}'

# ─── Pane zoom (Option+Shift+F → M-F) ────────────────
bind -n M-F resize-pane -Z

# ─── Pane resize (prefix + Shift+hjkl) ───────────────
bind -r H resize-pane -L 5
bind -r J resize-pane -D 5
bind -r K resize-pane -U 5
bind -r L resize-pane -R 5

# ─── Quick program windows ───────────────────────────
bind g new-window -n "lazygit" -c "#{pane_current_path}" "lazygit"
bind f new-window -n "files" -c "#{pane_current_path}" "lf"
bind e new-window -n "editor" -c "#{pane_current_path}" "nvim ."

# ─── Window navigation ───────────────────────────────
bind -n M-1 select-window -t 1
bind -n M-2 select-window -t 2
bind -n M-3 select-window -t 3
bind -n M-4 select-window -t 4
bind -n M-5 select-window -t 5
bind -n M-6 select-window -t 6
bind -n M-7 select-window -t 7
bind -n M-8 select-window -t 8
bind -n M-9 select-window -t 9

# ─── Copy mode (vi keys) ─────────────────────────────
setw -g mode-keys vi

# ─── Status bar (Tokyo Night) ────────────────────────
set -g status-style "bg=#1a1b26,fg=#565f89"
set -g status-left "#[fg=#7aa2f7,bold] #S "
set -g status-left-length 30
set -g status-right "#[fg=#565f89] %H:%M "
set -g window-status-current-format "#[fg=#7aa2f7,bold] #I:#W "
set -g window-status-format "#[fg=#565f89] #I:#W "
set -g pane-border-style "fg=#283457"
set -g pane-active-border-style "fg=#7aa2f7"
set -g message-style "bg=#1a1b26,fg=#c0caf5"

# ─── tmux-resurrect ──────────────────────────────────
# prefix + Ctrl-s to save, prefix + Ctrl-r to restore
if-shell "test -f ~/.config/tmux/plugins/tmux-resurrect/resurrect.tmux" \
  "run-shell ~/.config/tmux/plugins/tmux-resurrect/resurrect.tmux"
TMUX_CONF
}

readonly _ALACRITTY_MARKER_BEGIN="# --- kdev:begin ---"
readonly _ALACRITTY_MARKER_END="# --- kdev:end ---"
# Legacy markers — detected for one-time cleanup on migration
readonly _ALACRITTY_LEGACY_MARKER="# --- zproj-kostek: Cmd+hjkl tmux pane navigation ---"
readonly _ALACRITTY_LEGACY_MARKER_BEGIN="# --- zproj-kostek:begin ---"

_alacritty_keys_content() {
  cat <<ALACRITTY_KEYS

${_ALACRITTY_MARKER_BEGIN}
[window]
option_as_alt = "Both"
${_ALACRITTY_MARKER_END}
ALACRITTY_KEYS
}

# ─── Setup functions ─────────────────────────────────────────────────────────

_check_brew() {
  command -v brew &>/dev/null && return 0
  die "Homebrew not found. Install it first:\n\n  /bin/bash -c \"\$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)\"\n\nhttps://brew.sh"
}

_install_brew_formula() {
  local name="$1" binary="${2:-$1}"
  if command -v "$binary" &>/dev/null; then
    dim "  [installed]  $name"
    return 0
  fi
  step "Installing ${CYAN}${name}${RESET}..."
  brew install "$name"
  info "$name installed"
}

_install_brew_cask() {
  local name="$1" binary="${2:-$1}"
  if command -v "$binary" &>/dev/null; then
    dim "  [installed]  $name"
    return 0
  fi
  step "Installing ${CYAN}${name}${RESET} (cask)..."
  brew install --cask "$name"
  info "$name installed"
}

_install_pi_agent() {
  if command -v pi &>/dev/null; then
    dim "  [installed]  pi-coding-agent"
    return 0
  fi
  step "Installing ${CYAN}pi-coding-agent${RESET} via npm..."
  npm install -g @mariozechner/pi-coding-agent
  info "pi-coding-agent installed"
}

_write_tmux_conf() {
  local conf_dir="$HOME/.config/tmux"
  local conf_file="$conf_dir/tmux.conf"
  local old_conf="$HOME/.tmux.conf"

  # Back up ~/.tmux.conf so tmux reads the XDG-compliant location
  if [[ -f "$old_conf" ]]; then
    local backup="${old_conf}.bak"
    local n=1
    while [[ -f "$backup" ]]; do
      backup="${old_conf}.bak${n}"
      ((n++))
    done
    mv "$old_conf" "$backup"
    step "Backed up ${DIM}~/.tmux.conf${RESET} → ${DIM}$(basename "$backup")${RESET}"
  fi

  mkdir -p "$conf_dir"
  _tmux_conf_content > "$conf_file"
  info "Wrote ${conf_file}"
}

_append_alacritty_keys() {
  local conf_file="$HOME/.config/alacritty/alacritty.toml"

  if [[ ! -f "$conf_file" ]]; then
    warn "Alacritty config not found at ${conf_file} — skipping keybindings."
    return 0
  fi

  local updated=false

  # Remove legacy Cmd+hjkl block (v1.0–1.1 one-time migration)
  if grep -qF "$_ALACRITTY_LEGACY_MARKER" "$conf_file" 2>/dev/null; then
    sed -i '' "/$_ALACRITTY_LEGACY_MARKER/,/^$/{ /^$/!d; }" "$conf_file"
    sed -i '' '/^\[\[keyboard\.bindings\]\]/,/^$/{/^$/!d;}' "$conf_file"
    sed -i '' -e :a -e '/^\n*$/{$d;N;ba' -e '}' "$conf_file"
    updated=true
  fi

  # Remove legacy zproj-kostek:begin/end block (v1.2 → v2.0 rename migration)
  if grep -qF "$_ALACRITTY_LEGACY_MARKER_BEGIN" "$conf_file" 2>/dev/null; then
    sed -i '' "/$_ALACRITTY_LEGACY_MARKER_BEGIN/,/# --- zproj-kostek:end ---/d" "$conf_file"
    updated=true
  fi

  # Remove existing kdev begin/end block (idempotent replacement)
  if grep -qF "$_ALACRITTY_MARKER_BEGIN" "$conf_file" 2>/dev/null; then
    sed -i '' "/$_ALACRITTY_MARKER_BEGIN/,/$_ALACRITTY_MARKER_END/d" "$conf_file"
    updated=true
  fi

  _alacritty_keys_content >> "$conf_file"

  if $updated; then
    info "Updated Alacritty config (Option as Alt) in ${conf_file}"
  else
    info "Appended Option as Alt config to ${conf_file}"
  fi
}

_install_tmux_resurrect() {
  local plugin_dir="$HOME/.config/tmux/plugins/tmux-resurrect"

  if [[ -d "$plugin_dir" ]]; then
    dim "  [installed]  tmux-resurrect"
    return 0
  fi

  step "Installing ${CYAN}tmux-resurrect${RESET}..."
  mkdir -p "$(dirname "$plugin_dir")"
  git clone --quiet https://github.com/tmux-plugins/tmux-resurrect "$plugin_dir"
  info "tmux-resurrect installed → ${plugin_dir}"
}

# ─── Subcommand: setup ───────────────────────────────────────────────────────

cmd_setup() {
  local plan_only=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --plan)    plan_only=true ;;
      --help|-h) usage_setup; exit 0 ;;
      -*) die "Unknown option: $1." ;;
      *)  die "Unexpected argument: $1." ;;
    esac
    shift
  done

  echo ""
  echo -e "${BOLD}${SCRIPT_NAME} setup${RESET}$( $plan_only && echo " ${DIM}(dry run)${RESET}" || true)"
  echo ""

  if $plan_only; then
    echo -e "${BOLD}Tools:${RESET}"
    local tools=(
      "alacritty:alacritty:cask"
      "tmux:tmux:formula"
      "neovim:nvim:formula"
      "lazygit:lazygit:formula"
      "lf:lf:formula"
      "git:git:formula"
      "node:npm:formula"
    )
    local entry name binary kind
    for entry in "${tools[@]}"; do
      name="${entry%%:*}"; entry="${entry#*:}"
      binary="${entry%%:*}"; kind="${entry#*:}"
      if command -v "$binary" &>/dev/null; then
        echo -e "  ${DIM}[installed]${RESET}       $name"
      else
        echo -e "  [would install]  $name ($kind)"
      fi
    done
    if command -v pi &>/dev/null; then
      echo -e "  ${DIM}[installed]${RESET}       pi-coding-agent"
    else
      echo -e "  [would install]  pi-coding-agent (npm)"
    fi

    echo ""
    echo -e "${BOLD}Configs:${RESET}"

    if [[ -f "$HOME/.tmux.conf" ]]; then
      echo "  [would back up]     ~/.tmux.conf → ~/.tmux.conf.bak"
    fi
    if [[ -f "$HOME/.config/tmux/tmux.conf" ]]; then
      echo "  [would overwrite]   ~/.config/tmux/tmux.conf"
    else
      echo "  [would create]      ~/.config/tmux/tmux.conf"
    fi

    local alacritty_conf="$HOME/.config/alacritty/alacritty.toml"
    if [[ -f "$alacritty_conf" ]] && grep -qF "$_ALACRITTY_MARKER_BEGIN" "$alacritty_conf" 2>/dev/null; then
      echo -e "  ${DIM}[up to date]${RESET}        Alacritty Option-as-Alt config"
    elif [[ -f "$alacritty_conf" ]] && { grep -qF "$_ALACRITTY_LEGACY_MARKER" "$alacritty_conf" 2>/dev/null \
         || grep -qF "$_ALACRITTY_LEGACY_MARKER_BEGIN" "$alacritty_conf" 2>/dev/null; }; then
      echo "  [would migrate]     Alacritty config → kdev format"
    elif [[ -f "$alacritty_conf" ]]; then
      echo "  [would append]      Option-as-Alt config to alacritty.toml"
    else
      echo "  [not found]         alacritty.toml — will skip"
    fi

    if [[ -d "$HOME/.config/tmux/plugins/tmux-resurrect" ]]; then
      echo -e "  ${DIM}[installed]${RESET}         tmux-resurrect"
    else
      echo "  [would install]     tmux-resurrect plugin"
    fi

    echo ""
    if command -v "$SCRIPT_NAME" &>/dev/null; then
      echo -e "  ${DIM}[in PATH]${RESET}           $SCRIPT_NAME → $(command -v "$SCRIPT_NAME")"
    else
      echo "  [would ask]         symlink $SCRIPT_NAME into ~/.local/bin/"
    fi

    return 0
  fi

  _check_brew

  echo -e "${BOLD}Tools:${RESET}"
  _install_brew_cask alacritty
  _install_brew_formula tmux
  _install_brew_formula neovim nvim
  _install_brew_formula lazygit
  _install_brew_formula lf
  _install_brew_formula git
  _install_brew_formula node npm
  _install_pi_agent

  echo ""
  echo -e "${BOLD}Configs:${RESET}"
  _write_tmux_conf
  _append_alacritty_keys
  _install_tmux_resurrect

  # Offer to symlink into PATH
  echo ""
  if command -v "$SCRIPT_NAME" &>/dev/null; then
    dim "  [in PATH]  $SCRIPT_NAME → $(command -v "$SCRIPT_NAME")"
  else
    if _confirm "  Add ${BOLD}${SCRIPT_NAME}${RESET} to PATH via ~/.local/bin symlink?"; then
      local script_real target_dir target
      script_real="$(_script_path)"
      target_dir="$HOME/.local/bin"
      target="$target_dir/$SCRIPT_NAME"
      mkdir -p "$target_dir"
      ln -sf "$script_real" "$target"
      info "Symlinked ${target} → ${script_real}"
      # Check if ~/.local/bin is in PATH
      if [[ ":$PATH:" != *":$target_dir:"* ]]; then
        warn "~/.local/bin is not in your PATH."
        dim "  Add to ~/.zshrc:  export PATH=\"\$HOME/.local/bin:\$PATH\""
      fi
    else
      dim "  Skipped symlink. Run manually:"
      dim "    ln -s $(_script_path) ~/.local/bin/$SCRIPT_NAME"
    fi
  fi

  echo ""
  info "Setup complete. Restart Alacritty to apply changes."
  dim "  Reload tmux config:  tmux source-file ~/.config/tmux/tmux.conf"
}

# ─── Layout ───────────────────────────────────────────────────────────────────

# Create the 3-pane dev layout in an existing tmux window.
#
# ┌──────────────────┬──────────────────┐
# │                  │    lazygit       │
# │    pi agent      │   (top-right)    │
# │    (left, 50%)   ├──────────────────┤
# │                  │    nvim .        │
# │                  │  (bottom-right)  │
# └──────────────────┴──────────────────┘
_setup_dev_layout() {
  local session="$1" window="$2" dir="$3"

  local quoted_dir
  printf -v quoted_dir '%q' "$dir"

  local agent_cmd
  if command -v pi &>/dev/null; then
    agent_cmd="cd $quoted_dir && pi"
  else
    warn "pi-coding-agent not found — using shell. Install: npm i -g @mariozechner/pi-coding-agent"
    agent_cmd="cd $quoted_dir"
  fi

  # Pane 1 (left): already exists — coding agent
  local p1
  p1="$(tmux list-panes -t "$session:$window" -F '#{pane_id}' | head -1)"
  tmux send-keys -t "$p1" "$agent_cmd" Enter
  tmux select-pane -t "$p1" -T "agent"

  # Pane 2 (top-right): horizontal split — lazygit
  local p2
  p2="$(tmux split-window -t "$session:$window" -h -p 50 \
         -c "$dir" -P -F '#{pane_id}')"
  tmux send-keys -t "$p2" "lazygit" Enter
  tmux select-pane -t "$p2" -T "lazygit"

  # Pane 3 (bottom-right): vertical split of p2 — neovim
  local p3
  p3="$(tmux split-window -t "$p2" -v -p 65 \
         -c "$dir" -P -F '#{pane_id}')"
  tmux send-keys -t "$p3" "nvim ." Enter
  tmux select-pane -t "$p3" -T "nvim"

  # Focus the agent pane
  tmux select-pane -t "$p1"
}

# ─── Session launcher ────────────────────────────────────────────────────────

# Shared logic for dev and launch: create tmux session/window with layout,
# or switch to it if it already exists.
_launch_session() {
  local repo_root="$1" name="$2" wt_dir="$3"

  command -v tmux &>/dev/null || die "tmux not found. Run: ${CYAN}$SCRIPT_NAME setup${RESET}"

  local session_name window_name
  session_name="$(_tmux_session_name "$(basename "$repo_root")")"
  window_name="$name"

  if tmux has-session -t "$session_name" 2>/dev/null; then
    if tmux list-windows -t "$session_name" -F '#{window_name}' 2>/dev/null \
         | grep -qx "$window_name"; then
      info "Switching to ${BOLD}${session_name}:${window_name}${RESET}"
    else
      tmux new-window -t "$session_name:" -n "$window_name" -c "$wt_dir"
      _setup_dev_layout "$session_name" "$window_name" "$wt_dir"
      info "Created window ${BOLD}${session_name}:${window_name}${RESET}"
    fi
  else
    tmux new-session -d -s "$session_name" -n "$window_name" -c "$wt_dir" \
         -x 220 -y 50
    _setup_dev_layout "$session_name" "$window_name" "$wt_dir"
    info "Started session ${BOLD}${session_name}${RESET} window ${BOLD}${window_name}${RESET}"
  fi

  tmux select-window -t "$session_name:$window_name"
  _tmux_attach_or_switch "$session_name"
}

# ─── Subcommand: dev ─────────────────────────────────────────────────────────

cmd_dev() {
  local name="" from_ref=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h) usage_dev; exit 0 ;;
      --from)
        shift
        [[ $# -eq 0 ]] && die "--from requires a ref."
        from_ref="$1"
        ;;
      -*) die "Unknown option: $1." ;;
      *)
        [[ -n "$name" ]] && die "Too many arguments."
        name="$1"
        ;;
    esac
    shift
  done

  [[ -z "$name" ]] && die "Usage: $SCRIPT_NAME dev <name> [--from <ref>]"

  if ! git check-ref-format --branch "$name" &>/dev/null; then
    die "Invalid name: '$name'. Must be a valid git branch name."
  fi

  local repo_root
  repo_root="$(_find_repo_root)" || die "Not inside a git repository.\n  Run this command from within a git repo."

  local wt_dir="$repo_root/$WORKTREES_DIR/$name"

  # Create worktree if it doesn't exist
  if [[ ! -d "$wt_dir" ]]; then
    mkdir -p "$repo_root/$WORKTREES_DIR"
    _ensure_gitignore "$repo_root" "$WORKTREES_DIR"

    if [[ -z "$from_ref" ]]; then
      from_ref="$(_git_default_branch "$repo_root")" || from_ref="HEAD"
    fi

    # Validate the from-ref
    if [[ "$from_ref" != "HEAD" ]]; then
      git -C "$repo_root" rev-parse --verify "${from_ref}^{commit}" &>/dev/null ||
        die "Ref '$from_ref' does not exist."
    fi

    if git -C "$repo_root" show-ref --verify --quiet "refs/heads/$name" 2>/dev/null; then
      # Branch already exists — create worktree on existing branch
      step "Creating worktree ${BOLD}${name}${RESET} (existing branch)..."
      git -C "$repo_root" worktree add "$wt_dir" "$name" --quiet ||
        die "Failed to create worktree. Is branch '$name' already checked out?"
    else
      step "Creating worktree ${BOLD}${name}${RESET} from ${CYAN}${from_ref}${RESET}..."
      git -C "$repo_root" worktree add "$wt_dir" -b "$name" "$from_ref" --quiet ||
        die "Failed to create worktree."
    fi

    info "Worktree ${BOLD}${name}${RESET} → branch ${CYAN}${name}${RESET}"
  else
    dim "Worktree ${name} already exists"
  fi

  _launch_session "$repo_root" "$name" "$wt_dir"
}

# ─── Subcommand: launch ──────────────────────────────────────────────────────

cmd_launch() {
  local name=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h) usage_launch; exit 0 ;;
      -*) die "Unknown option: $1." ;;
      *)
        [[ -n "$name" ]] && die "Too many arguments."
        name="$1"
        ;;
    esac
    shift
  done

  [[ -z "$name" ]] && die "Usage: $SCRIPT_NAME launch <name>"

  local repo_root
  repo_root="$(_find_repo_root)" || die "Not inside a git repository."

  local wt_dir="$repo_root/$WORKTREES_DIR/$name"
  [[ ! -d "$wt_dir" ]] && die "Worktree '$name' does not exist.\n  Create it with: ${CYAN}$SCRIPT_NAME dev $name${RESET}"

  _launch_session "$repo_root" "$name" "$wt_dir"
}

# ─── Subcommand: list ────────────────────────────────────────────────────────

cmd_list() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h) usage_list; exit 0 ;;
      -*) die "Unknown option: $1." ;;
      *)  die "Unexpected argument: $1." ;;
    esac
    shift
  done

  local repo_root
  repo_root="$(_find_repo_root)" || die "Not inside a git repository."

  local wt_base="$repo_root/$WORKTREES_DIR"
  local session_name
  session_name="$(_tmux_session_name "$(basename "$repo_root")")"

  if [[ ! -d "$wt_base" ]] || [[ -z "$(ls -A "$wt_base" 2>/dev/null)" ]]; then
    echo ""
    echo -e "  No worktrees found. Create one with: ${CYAN}$SCRIPT_NAME dev <name>${RESET}"
    return 0
  fi

  # Gather tmux window names
  local -a tmux_windows=()
  if command -v tmux &>/dev/null && tmux has-session -t "$session_name" 2>/dev/null; then
    while IFS= read -r win; do
      tmux_windows+=("$win")
    done < <(tmux list-windows -t "$session_name" -F '#{window_name}:#{window_active}' 2>/dev/null)
  fi

  echo ""
  echo -e "  ${BOLD}$(basename "$repo_root")${RESET} worktrees:  ${DIM}(session: ${session_name})${RESET}"
  echo ""
  printf "  ${DIM}%-20s %-20s %-10s %-10s${RESET}\n" "NAME" "BRANCH" "STATUS" "TMUX"
  printf "  ${DIM}%-20s %-20s %-10s %-10s${RESET}\n" "────" "──────" "──────" "────"

  local dir name branch status window_status
  for dir in "$wt_base"/*/; do
    [[ -d "$dir" ]] || continue
    name="$(basename "$dir")"

    branch="$(git -C "$dir" rev-parse --abbrev-ref HEAD 2>/dev/null)" || branch="?"

    if _git_is_dirty "$dir"; then
      status="${YELLOW}dirty${RESET}"
    else
      status="${GREEN}clean${RESET}"
    fi

    window_status="${DIM}none${RESET}"
    local win_entry
    for win_entry in "${tmux_windows[@]+"${tmux_windows[@]}"}"; do
      local wn="${win_entry%%:*}" wa="${win_entry##*:}"
      if [[ "$wn" == "$name" ]]; then
        if [[ "$wa" == "1" ]]; then
          window_status="${CYAN}active${RESET}"
        else
          window_status="open"
        fi
        break
      fi
    done

    printf "  %-20s %-20s %-21b %-21b\n" "$name" "$branch" "$status" "$window_status"
  done
  echo ""
}

# ─── Subcommand: delete ──────────────────────────────────────────────────────

cmd_delete() {
  local name="" force=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h) usage_delete; exit 0 ;;
      --force|-f) force=true ;;
      -*) die "Unknown option: $1." ;;
      *)
        [[ -n "$name" ]] && die "Too many arguments."
        name="$1"
        ;;
    esac
    shift
  done

  [[ -z "$name" ]] && die "Usage: $SCRIPT_NAME delete <name> [--force]"

  local repo_root
  repo_root="$(_find_repo_root)" || die "Not inside a git repository."

  local wt_dir="$repo_root/$WORKTREES_DIR/$name"
  [[ ! -d "$wt_dir" ]] && die "Worktree '$name' does not exist."

  local session_name
  session_name="$(_tmux_session_name "$(basename "$repo_root")")"

  # Kill tmux window if open
  if command -v tmux &>/dev/null && tmux has-session -t "$session_name" 2>/dev/null; then
    if tmux list-windows -t "$session_name" -F '#{window_name}' 2>/dev/null \
         | grep -qx "$name"; then
      if [[ "$force" != true ]]; then
        die "tmux window '${name}' is still open.\n  Close it first, or use ${CYAN}--force${RESET}."
      fi
      step "Killing tmux window ${BOLD}${session_name}:${name}${RESET}..."
      tmux kill-window -t "$session_name:$name" 2>/dev/null || true
    fi
  fi

  # Check for uncommitted changes
  if [[ "$force" != true ]] && _git_is_dirty "$wt_dir"; then
    die "Worktree '$name' has uncommitted changes.\n  Commit or stash them, or use ${CYAN}--force${RESET}."
  fi

  local branch_name
  branch_name="$(git -C "$wt_dir" rev-parse --abbrev-ref HEAD 2>/dev/null)" || true

  step "Removing worktree ${BOLD}${name}${RESET}..."
  if [[ "$force" == true ]]; then
    git -C "$repo_root" worktree remove --force "$wt_dir" 2>/dev/null ||
      rm -rf "$wt_dir"
  else
    git -C "$repo_root" worktree remove "$wt_dir"
  fi

  git -C "$repo_root" worktree prune --quiet 2>/dev/null || true

  # Only delete the branch when it matches the worktree name
  if [[ -n "${branch_name:-}" && "$branch_name" == "$name" && "$branch_name" != "HEAD" ]]; then
    if git -C "$repo_root" branch -d "$branch_name" &>/dev/null; then
      dim "  Deleted branch $branch_name"
    elif [[ "$force" == true ]]; then
      git -C "$repo_root" branch -D "$branch_name" &>/dev/null &&
        dim "  Force-deleted branch $branch_name"
    fi
  fi

  info "Removed ${BOLD}${name}${RESET}"
}

# ─── Usage ────────────────────────────────────────────────────────────────────

usage_main() {
  cat <<EOF
